# Unsplash (free stock photo search for Marketing + Events Director)
# Register at https://unsplash.com/developers, create an app, paste the Access Key here.
# Demo tier: 50 requests/hour per application. Attribution required.
UNSPLASH_ACCESS_KEY=

# Composio (social posting broker for Marketing Director — Instagram, Facebook,
# LinkedIn, TikTok, X/Twitter, Threads). Sign up at https://composio.dev,
# create an API key, paste it here. Free tier: 20K tool calls/mo. $29/mo Starter.
# Without this set, the social_post tool returns a "not configured" error.
COMPOSIO_API_KEY=

# Brand: PRIVATE BETA pill visibility in navbar/sidebar logo lockup.
# Omit (or set to anything other than "false") to show the pill.
# Set to "false" to hide it when the product exits private beta.
NEXT_PUBLIC_SHOW_BETA_BADGE=
