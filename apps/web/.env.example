# --- App URL (required for Google OAuth redirect URI in production) ---
# Set this in Vercel: NEXT_PUBLIC_APP_URL=https://edifyos.vercel.app
# Without this, getAppOrigin() falls back to VERCEL_URL (preview deployment URL),
# causing a redirect_uri_mismatch with Google Cloud Console.
NEXT_PUBLIC_APP_URL=

# --- Google Workspace OAuth (Gmail + Calendar + Drive integration) ---
# Register at https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client (Web application type).
# Add authorized redirect URI: https://edifyos.vercel.app/api/integrations/google/callback
# Also add http://localhost:3000/api/integrations/google/callback for local dev.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Unsplash (free stock photo search for Marketing + Events Director) ---
# Register at https://unsplash.com/developers, create an app, paste the Access Key here.
# Demo tier: 50 requests/hour per application. Attribution required.
UNSPLASH_ACCESS_KEY=

# Composio (social posting broker for Marketing Director — Instagram, Facebook,
# LinkedIn, TikTok, X/Twitter, Threads). Sign up at https://composio.dev,
# create an API key, paste it here. Free tier: 20K tool calls/mo. $29/mo Starter.
# Without this set, the social_post tool returns a "not configured" error.
COMPOSIO_API_KEY=

# Brand: PRIVATE BETA pill visibility in navbar/sidebar logo lockup.
# Omit (or set to anything other than "false") to show the pill.
# Set to "false" to hide it when the product exits private beta.
NEXT_PUBLIC_SHOW_BETA_BADGE=

# TikTok integration (Marketing Director — drafts mode only, not auto-post).
# Default: false. Set to "true" in Vercel (or .env.local) to enable TikTok as a
# platform option for Kida. When false, TikTok is omitted from all platform lists.
ENABLE_TIKTOK=false

# --- Charity Navigator (free GraphQL API — Dev Director ratings/accountability) ---
# Register a free developer account at https://developer.charitynavigator.org/.
# After approval, paste the API key here. Sent as the raw `Authorization`
# header value (no "Bearer " prefix) per Charity Navigator's cn-examples README.
# Without this set, charity_navigator_* tools return a "not configured" error.
CHARITY_NAVIGATOR_API_KEY=

# --- Candid Demographics (free DEI / leadership / staff demographic data) ---
# Candid markets the Demographics API as "freely available to all" but the
# developer portal still requires registering for a Subscription Key.
# Sign up at https://developer.candid.org/, request the Demographics API,
# paste the key here. Sent as the `Subscription-Key` header (Azure API Mgmt).
# Without this set, candid_demographics_* tools return a "not configured" error.
CANDID_DEMOGRAPHICS_API_KEY=

# --- Zapier MCP (meta-connector — Marketing / Programs / Development /
# Events / Executive Assistant; proxies Mailchimp, Eventbrite, Bloomerang,
# Neon, Typeform, Google Forms, etc.) ---
# 1. Visit https://mcp.zapier.com/ and click "+ New MCP Server".
# 2. Pick the "Anthropic API" client type.
# 3. In the Configure tab, click "+ Add tool" and choose the apps/actions
#    each archetype needs (e.g. Mailchimp - Send Campaign, Eventbrite - List
#    Attendees, Typeform - List Responses).
# 4. Switch to the Connect tab and copy the server URL.
# 5. Paste the FULL URL here as ZAPIER_MCP_URL. The URL embeds a per-server
#    secret token in its path — Zapier's docs explicitly say "keep this secret
#    — it's like a password". Treat it as a credential, not a public URL.
# Without this set, Zapier is silently dropped from the MCP server list.
# Reference: https://zapier.com/blog/zapier-mcp-anthropic-api/
ZAPIER_MCP_URL=

# --- Canva (OAuth + MCP integration — Marketing Director graphic generation) ---
# Register a Canva developer app at https://www.canva.dev/developers/
# Required scopes: design:content:read design:content:write asset:read asset:write profile:read
# Set redirect URI to: https://<your-domain>/api/integrations/canva/callback
# (also add http://localhost:3000/api/integrations/canva/callback for local dev)
CANVA_OAUTH_CLIENT_ID=
CANVA_OAUTH_CLIENT_SECRET=
CANVA_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/canva/callback
